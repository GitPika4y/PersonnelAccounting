<UserControl x:Class="WPF_Desktop.Views.Modal.AccountPickerModalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <StackPanel Margin="20">
        <TextBlock Text="Совершенные ранее входы:"
                   FontSize="24"/>

        <ListBox ItemsSource="{Binding Accounts}"
                 Margin="0 20"
                 Style="{StaticResource MaterialDesignCardsListBox}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="10 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                    Margin="0 10"
                                    Command="{Binding DataContext.LogInCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource MaterialDesignPaperButton}">
                            <StackPanel>
                                <TextBlock Text="{Binding Login}"
                                           FontSize="18"/>
                                <TextBlock Text="Вход не выполнен"
                                           Visibility="{Binding IsLogged, Converter={StaticResource InvertBoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1"
                                Margin="10 0"
                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl }}"
                                CommandParameter="{Binding}">
                            <md:PackIcon Kind="Delete"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Text="Авторизоваться"
                   TextAlignment="Right"
                   Foreground="DarkGoldenrod"
                   FontSize="16"
                   TextDecorations="Underline"
                   FontStyle="Italic"
                   Cursor="Hand">

            <TextBlock.InputBindings>
                <MouseBinding MouseAction="LeftClick"
                              Command="{x:Static md:DialogHost.CloseDialogCommand}"/>
            </TextBlock.InputBindings>
        </TextBlock>
    </StackPanel>
</UserControl>
