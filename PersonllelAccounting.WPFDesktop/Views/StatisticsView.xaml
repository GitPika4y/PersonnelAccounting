<UserControl x:Class="WPF_Desktop.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:WPF_Desktop.Components"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="StatisticsView_OnLoaded">

	<Grid Margin="5">
		<Grid.ColumnDefinitions>
			<ColumnDefinition />
			<ColumnDefinition />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition/>
			<RowDefinition/>
		</Grid.RowDefinitions>

		<!-- FIRST ROW -->
		<md:Card Grid.Row="0"
		         Grid.Column="0"
		         Margin="5">
			<components:PieChart Series="{Binding OrdersTypePieSeries}"
			                     Title="Типы приказов"
			                     TextSize="16"/>
		</md:Card>

		<md:Card Grid.Row="0"
		         Grid.Column="1"
		         Margin="5">
			<components:CartesianChart Series="{Binding EmployeesHireCartesianSeries}"
			                           XAxes="{Binding EmployeeHireCartesianXAxes}"
			                           Title="Нанято сотрудников за последние дни"
			                           TextSize="16"/>
		</md:Card>

		<md:Card Grid.Row="0"
		         Grid.Column="2"
		         Margin="5">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="*"/>
					<RowDefinition Height="AUTO"/>
				</Grid.RowDefinitions>

				<components:PieChart Grid.Row="0"
				                     Series="{Binding EmployeesDepartmentPositionPieSeries}"
				                     Title="{Binding EmployeesDepartmentPositionTitle}"
				                     TextSize="16"/>

				<components:EnumComboBox Grid.Row="1"
				                         ItemsSource="{Binding EmployeeSeriesTypes}"
				                         SelectedItem="{Binding SelectedEmployeeSeriesType}"
				                         md:HintAssist.Hint="Фильтровать по"/>
			</Grid>
		</md:Card>

		<!-- SECOND ROW -->
		<md:Card Grid.Row="1"
		         Grid.Column="0"
		         Grid.ColumnSpan="2"
		         Margin="5">
			<components:CartesianChart Series="{Binding NewOrdersCartesianSeries}"
			                           XAxes="{Binding NewOrdersCartesianXAxes}"
			                           Title="Новые приказы за последние дни"
			                           TextSize="16"/>
		</md:Card>

		<md:Card Grid.Row="1"
		         Grid.Column="2"
		         Margin="5"
		         Padding="5">
			<StackPanel>
				<TextBlock Text="Статистика"
				           HorizontalAlignment="Center"
				           FontWeight="Bold"
				           Margin="0 0 0 10"
				           Style="{StaticResource MaterialDesignHeadlineSmallTextBlock}"/>

				<components:KeyValueHorizontalGrid Key="Общее число приказов"
				                                   Value="{Binding OrdersCount}"
				                                   UseTextBox="False"
				                                   Margin="0 0 0 10"/>
				<components:KeyValueHorizontalGrid Key="Общее число сотрудников"
				                                   Value="{Binding EmployeesCount}"
				                                   UseTextBox="False"
				                                   Margin="0 0 0 10"/>
				<components:KeyValueHorizontalGrid Key="Количество отделов"
				                                   Value="{Binding DepartmentsCount}"
				                                   UseTextBox="False"
				                                   Margin="0 0 0 10"/>
				<components:KeyValueHorizontalGrid Key="Количество должностей"
				                                   Value="{Binding PositionsCount}"
				                                   UseTextBox="False"
				                                   Margin="0 0 0 10"/>
				<components:KeyValueHorizontalGrid Key="Самая популярная должность при найме"
				                                   Value="{Binding MostPopularPosition,
													TargetNullValue=Никакая}"
				                                   UseTextBox="False"
				                                   Margin="0 0 0 10"/>
				<components:KeyValueHorizontalGrid Key="Коэффициент текучести кадров"
				                                   Value="{Binding HireToFireRate,
													StringFormat={}{0:0.00}}"
				                                   UseTextBox="False"
				                                   Margin="0 0 0 10"/>
			</StackPanel>
		</md:Card>
	</Grid>
</UserControl>