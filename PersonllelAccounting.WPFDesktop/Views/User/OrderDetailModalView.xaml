<UserControl x:Class="WPF_Desktop.Views.User.OrderDetailModalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Data.Models.Main;assembly=PersonnelAccounting.DataAccess"
             xmlns:components="clr-namespace:WPF_Desktop.Components"
             xmlns:partials="clr-namespace:WPF_Desktop.Views.User.Partials"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
		</Grid.RowDefinitions>

		<!-- TITLE -->
		<TextBlock Grid.Row="0"
		           Text="Приказ"
		           Margin="0 10"
		           HorizontalAlignment="Center"
		           Style="{StaticResource MaterialDesignHeadlineLargeTextBlock}"/>

		<!-- CONTENT -->
		<ScrollViewer Grid.Row="1"
		              VerticalScrollBarVisibility="Auto"
		              DataContext="{Binding Order}">
			<StackPanel>
				<GroupBox Header="Основные данные"
				          FontSize="16"
				          Margin="10">
					<partials:OrderRequiredPartial/>
				</GroupBox>

				<!-- OPTIONAL -->
				<GroupBox Header="{Binding Type,
	                        Converter={StaticResource EnumToDisplayNameConverter}}"
				          Margin="10"
				          FontSize="16">

					<GroupBox.Visibility>
						<MultiBinding Converter="{StaticResource IntersectionToVisibilityConverter}">
							<Binding Path="Type"/>
							<Binding Source="{x:Static models:OrderType.Hire}"/>
							<Binding Source="{x:Static models:OrderType.Fire}"/>
						</MultiBinding>
					</GroupBox.Visibility>

					<StackPanel>
						<components:VisibilityControl Value="{Binding Type}"
						                              TargetValue="{x:Static models:OrderType.Hire}">
							<partials:OrderHirePartial Margin="20"/>
						</components:VisibilityControl>
						<components:VisibilityControl Value="{Binding Type}"
						                              TargetValue="{x:Static models:OrderType.Fire}">
							<partials:OrderFirePartial Margin="20"/>
						</components:VisibilityControl>

					</StackPanel>
				</GroupBox>
			</StackPanel>
		</ScrollViewer>

		<!-- ACTION BUTTONS -->
		<Button Grid.Row="2"
		        Content="Назад"
		        Style="{StaticResource MaterialDesignOutlinedSecondaryButton}"
		        Command="{x:Static md:DialogHost.CloseDialogCommand}"
		        Margin="10"/>
	</Grid>
</UserControl>
