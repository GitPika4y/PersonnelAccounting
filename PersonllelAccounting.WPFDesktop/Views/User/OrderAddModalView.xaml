<UserControl x:Class="WPF_Desktop.Views.User.OrderAddModalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:partials="clr-namespace:WPF_Desktop.Views.User.Partials"
             xmlns:components="clr-namespace:WPF_Desktop.Components"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:Data.Models.Main;assembly=PersonnelAccounting.DataAccess">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Grid.Row="0"
                   Text="Создать приказ"
                   Style="{StaticResource MaterialDesignDisplaySmallTextBlock}"
                   Margin="0 20"
                   HorizontalAlignment="Center"/>

        <!-- EMPLOYEES -->
        <GroupBox Grid.Column="0"
                  Grid.Row="1"
                  Margin="20 0"
                  Header="Сотрудники"
                  FontSize="18"
                  Visibility="{Binding HasEmployee,
                    Converter={StaticResource InvertBoolToVisibilityConverter}}">
            <components:PaginationControl>
                <DataGrid ItemsSource="{Binding Employees}"
                          SelectedItem="{Binding SelectedEmployee}"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status, Converter={StaticResource EnumToDisplayNameConverter}}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </components:PaginationControl>
        </GroupBox>

        <!-- MAIN CONTENT -->
        <StackPanel Grid.Column="1"
                    Grid.Row="1"
                    Orientation="Horizontal">
            <GroupBox FontSize="18"
                      Margin="10 0"
                      Header="Общее">
                <StackPanel Margin="20 0">
                    <partials:OrderRequiredAddPartial />

                    <components:EnumComboBox ItemsSource="{Binding OrderTypes}"
                                             SelectedItem="{Binding SelectedOrderType}"
                                             Margin="0 10"
                                             md:HintAssist.Hint="Тип приказа"/>
                </StackPanel>
            </GroupBox>

            <!-- OPTIONS -->
            <GroupBox Header="{Binding SelectedOrderType,
                        Converter={StaticResource EnumToDisplayNameConverter}}"
                      Margin="20 0"
                      FontSize="18">

                <GroupBox.Visibility>
                    <MultiBinding Converter="{StaticResource IntersectionToVisibilityConverter}">
                        <Binding Path="SelectedOrderType"/>
                        <Binding Source="{x:Static models:OrderType.Hire}"/>
                        <Binding Source="{x:Static models:OrderType.Fire}"/>
                    </MultiBinding>
                </GroupBox.Visibility>

                <StackPanel>
                    <components:VisibilityControl Value="{Binding SelectedOrderType}"
                                                  TargetValue="{x:Static models:OrderType.Hire}">
                        <partials:OrderHireAddPartial Margin="20"/>
                    </components:VisibilityControl>

                    <components:VisibilityControl Value="{Binding SelectedOrderType}"
                                                  TargetValue="{x:Static models:OrderType.Fire}">
                        <partials:OrderFireAddPartial Margin="20"/>
                    </components:VisibilityControl>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <!-- ACTION BUTTONS -->
        <Grid Grid.Column="0"
              Grid.ColumnSpan="2"
              Grid.Row="2"
              Margin="0 20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Создать"
                    Command="{Binding SaveCommand}"
                    Margin="0 0 10 0"/>

            <Button Grid.Column="1"
                    Content="Закрыть"
                    Command="{x:Static md:DialogHost.CloseDialogCommand}"
                    Margin="10 0 0 0"
                    Style="{StaticResource MaterialDesignOutlinedSecondaryButton}"/>
        </Grid>
    </Grid>
</UserControl>
