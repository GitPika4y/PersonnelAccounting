<UserControl x:Class="WPF_Desktop.Views.User.Partials.EmployeeEducationAddEditPartial"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:components="clr-namespace:WPF_Desktop.Components">
    <StackPanel>
        <components:EnumComboBox ItemsSource="{Binding Qualifications}"
                                 SelectedItem="{Binding Qualification}"
                                 md:HintAssist.Hint="Квалификация"
                                 Margin="20"/>

        <components:EnumComboBox ItemsSource="{Binding Specializations}"
                                 SelectedItem="{Binding Specialization}"
                                 md:HintAssist.Hint="Специализация"
                                 Margin="20"/>


        <TextBox Text="{Binding GraduationYear, UpdateSourceTrigger=PropertyChanged}"
                 md:HintAssist.Hint="Год окончания"
                 Margin="20"/>
    </StackPanel>
</UserControl>
