<UserControl x:Class="WPF_Desktop.Views.User.Partials.OrderHirePartial"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:WPF_Desktop.Components">

	<StackPanel>
		<components:KeyValueHorizontalGrid Key="Отдел"
		                                   Value="{Binding HireDepartment.Title}"
		                                   Margin="0 0 0 10"/>

		<components:KeyValueHorizontalGrid Key="Должность"
		                                   Value="{Binding HirePosition.Title}"/>
	</StackPanel>
</UserControl>
