<UserControl x:Class="WPF_Desktop.Views.User.Partials.EmployeeDocumentsPartial"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:WPF_Desktop.Components">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <components:KeyValueHorizontalGrid Grid.Column="0"
                                      Grid.Row="0"
                                      Key="Серия"
                                      Value="{Binding Employee.Passport.Serial}"
                                      UseTextBox="True"
                                      Margin="0 0 10 10"/>

            <components:KeyValueHorizontalGrid Grid.Column="1"
                                      Grid.Row="0"
                                      Key="Номер"
                                      Value="{Binding Employee.Passport.Number}"
                                      UseTextBox="True"
                                      Margin="10 0 0 10"/>

            <components:KeyValueBlock Grid.Column="0"
                                      Grid.Row="1"
                                      Key="Дата"
                                      Value="{Binding Employee.Passport.Date}"
                                      UseTextBox="True"
                                      Margin="0 10 10 0"
                                      Orientation="Vertical"/>

            <components:KeyValueBlock Grid.Column="1"
                                      Grid.Row="1"
                                      Key="Кем выдан"
                                      Value="{Binding Employee.Passport.GivenBy}"
                                      UseTextBox="True"
                                      Margin="10 10 0 0"
                                      Orientation="Vertical"/>
        </Grid>
</UserControl>