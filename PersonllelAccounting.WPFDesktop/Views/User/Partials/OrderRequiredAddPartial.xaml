<UserControl x:Class="WPF_Desktop.Views.User.Partials.OrderRequiredAddPartial"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:WPF_Desktop.Components"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <StackPanel>
        <components:KeyValueBlock Key="Сотрудник"
                                  Value="{Binding SelectedEmployee.FullName,
                                    TargetNullValue=Выберите из списка}"
                                  Margin="0 15"
                                  UseTextBox="False"/>

        <DatePicker SelectedDate="{Binding Date}"
                    Margin="0 15"
                    md:HintAssist.Hint="Дата создания приказа"/>

        <DatePicker SelectedDate="{Binding StartDate}"
                    Margin="0 15"
                    md:HintAssist.Hint="Дата вступления приказа в силу"/>

        <DatePicker SelectedDate="{Binding EndDate}"
                    Margin="0 15"
                    md:HintAssist.Hint="Дата окончания силы приказа"/>
    </StackPanel>
</UserControl>
