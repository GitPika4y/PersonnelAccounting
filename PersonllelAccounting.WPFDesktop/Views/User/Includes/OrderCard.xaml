<UserControl x:Class="WPF_Desktop.Views.User.Includes.OrderCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:WPF_Desktop.Components"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Name="Root">

	<md:Card Style="{StaticResource OutlinedCard}"
	         Padding="10"
	         FontSize="18">
		<StackPanel>
			<TextBlock Text="{Binding Date,
						  StringFormat={}Приказ от: {0:dd.MM.YYYY},
						  Converter={StaticResource DateOrInfiniteConverter}}"
			           Style="{StaticResource MaterialDesignTitleLargeTextBlock}"
			           HorizontalAlignment="Center"/>

			<Line Margin="0 10"/>

			<components:KeyValueHorizontalGrid Key="Сотрудник"
			                                   Value="{Binding Employee.FullName}"
			                                   UseTextBox="False"
			                                   Margin="0 0 0 10"/>

			<components:KeyValueHorizontalGrid Key="Вступит в силу"
			                                   Value="{Binding StartDate,
												Converter={StaticResource DateOrInfiniteConverter}}"
			                                   UseTextBox="False"
			                                   Margin="0 0 0 10"/>

			<components:KeyValueHorizontalGrid Key="Тип приказа"
			                                   Value="{Binding Type,
												Converter={StaticResource EnumToDisplayNameConverter}}"
			                                   UseTextBox="False"
			                                   Margin="0 0 0 10"/>

			<components:KeyValueHorizontalGrid Key="Статус приказа"
			                                   Value="{Binding Status,
												Converter={StaticResource EnumToDisplayNameConverter}}"
			                                   UseTextBox="False"
			                                   Margin="0 0 0 10"/>

			<components:KeyValueHorizontalGrid Key="Действует до"
			                                   Value="{Binding EndDate,
												Converter={StaticResource DateOrInfiniteConverter}}"
			                                   UseTextBox="False"
			                                   Margin="0 0 0 10"/>

			<Button Content="Подробнее"
			        Command="{Binding OnDetailClickCommand,
                        ElementName=Root}"
			        CommandParameter="{Binding}"
			        Margin="10"
			        Style="{StaticResource MaterialDesignOutlinedSecondaryLightButton}"
			        Visibility="{Binding IsSelected,
                        RelativeSource={RelativeSource AncestorType=ListBoxItem},
                        Converter={StaticResource BoolToVisibilityConverter}}"/>
		</StackPanel>
	</md:Card>
</UserControl>
