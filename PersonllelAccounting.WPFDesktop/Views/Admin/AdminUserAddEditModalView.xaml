<UserControl x:Class="WPF_Desktop.Views.Admin.AdminUserAddEditModalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             MinWidth="300">

    <StackPanel Margin="15">
        <TextBlock Text="{Binding ModalTitle}"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 30"
                   Style="{StaticResource MaterialDesignDisplayLargeTextBlock}"/>

        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0 0 0 30"
                 FontSize="24"
                 md:HintAssist.Hint="Логин"/>

        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0 0 0 30"
                 FontSize="24"
                 md:HintAssist.Hint="Пароль"/>

        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0 0 0 30"
                 FontSize="24"
                 md:HintAssist.Hint="Псевдоним"/>

        <ComboBox ItemsSource="{Binding Roles}"
                  SelectedItem="{Binding Role}"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  Margin="0 0 0 30"
                  FontSize="24"
                  md:HintAssist.Hint="Роль">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource EnumToDisplayNameConverter}}"
                               FontSize="22"
                               />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <Grid Margin="0 30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="{Binding ModalBtnText}"
                    Command="{Binding SaveCommand}"
                    Margin="0 0 10 0"
                    FontSize="24"
                    Height="60"
                    />

            <Button Grid.Column="1"
                    Content="Назад"
                    Command="{x:Static md:DialogHost.CloseDialogCommand}"
                    Margin="10 0 0 0"
                    FontSize="24"
                    Height="60"
                    Style="{StaticResource MaterialDesignOutlinedSecondaryButton}"/>
        </Grid>
    </StackPanel>
</UserControl>
