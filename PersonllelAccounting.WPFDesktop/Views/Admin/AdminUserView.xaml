<UserControl x:Class="WPF_Desktop.Views.Admin.AdminUserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Grid.Row="0"
                   Text="Пользователи"
                   Style="{StaticResource MaterialDesignDisplayMediumTextBlock}"
                   FontSize="48"
                   FontWeight="SemiBold"
                   Margin="0 0 0 30"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   />

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0 20">
            <ListBox ItemsSource="{Binding Users}"
                     SelectedItem="{Binding SelectedUser}"
                     SelectionMode="Single"
                     BorderThickness="0"
                     Background="Transparent">

                <ListBox.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Редактировать"
                                   Command="{Binding EditUserCommand}"
                                  />
                    </ContextMenu>
                </ListBox.ContextMenu>

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="300" ItemHeight="Auto"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <md:Card Padding="25"
                                 Width="300"
                                 Background="Goldenrod"
                                 Cursor="Hand">
                            <StackPanel>
                                <TextBlock Margin="0 0 0 10">
                                    <Run Text="Логин: " FontSize="26" FontWeight="Bold"/>
                                    <Run Text="{Binding Login}" FontSize="24" FontWeight="Medium"/>
                                </TextBlock>

                                <TextBlock Margin="0 0 0 10">
                                    <Run Text="Роль: " FontSize="26" FontWeight="Bold"/>
                                    <Run Text="{Binding Role, Converter={StaticResource EnumToDisplayNameConverter}}" FontSize="24" FontWeight="Medium"/>
                                </TextBlock>

                                <TextBlock>
                                    <Run Text="Псевдоним: " FontSize="26" FontWeight="Bold"/>
                                    <Run Text="{Binding Username}" FontSize="24" FontWeight="Medium"/>
                                </TextBlock>
                            </StackPanel>
                        </md:Card>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <!-- ACTION_BUTTONS -->
        <Grid Grid.Row="2"
              Margin="0 30 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Добавить -->
            <Button Grid.Column="0"
                    Content="ДОБАВИТЬ"
                    Command="{Binding AddUserCommand}"
                    Height="45"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="White"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>

            <!-- Обновить -->
            <Button Grid.Column="2"
                    Content="РЕДАКТИРОВАТЬ"
                    Command="{Binding EditUserCommand}"
                    Height="45"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="White"
                    Style="{StaticResource MaterialDesignRaisedSecondaryLightButton}"/>
        </Grid>
    </Grid>
</UserControl>