<UserControl x:Class="WPF_Desktop.Components.KeyValueBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="{Binding Orientation, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <TextBlock Text="{Binding Key, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0}: }"
             FontWeight="Bold"
             VerticalAlignment="Center"
             Margin="0 0 15 0"/>

        <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Visibility="{Binding UseTextBox,
                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                        Converter={StaticResource InvertBoolToVisibilityConverter}}"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"/>

        <TextBox Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 Visibility="{Binding UseTextBox,
                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                        Converter={StaticResource BoolToVisibilityConverter}}"
                 IsEnabled="False"
                 VerticalAlignment="Center"
                 TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
