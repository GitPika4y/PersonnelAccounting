<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
                    >

    <Style TargetType="TextBox"
           BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"/>

    <Style TargetType="DatePicker"
           BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}"/>

    <Style TargetType="ComboBox"
           BasedOn="{StaticResource MaterialDesignOutlinedComboBox}"/>

    <Style TargetType="{x:Type md:Card}"
           BasedOn="{StaticResource MaterialDesignOutlinedCard}"
           x:Key="OutlinedCard">
           <Setter Property="Effect" Value="{StaticResource MaterialDesignElevationShadow3}"/>
    </Style>

    <Style TargetType="GroupBox"
           BasedOn="{StaticResource MaterialDesignCardGroupBox}">
           <Setter Property="Effect" Value="{StaticResource MaterialDesignElevationShadow4}"/>
    </Style>
</ResourceDictionary>